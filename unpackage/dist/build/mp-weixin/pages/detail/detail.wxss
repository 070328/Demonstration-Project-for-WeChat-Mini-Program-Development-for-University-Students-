.page{min-height:100vh;background:#f5f7fa;width:100%;box-sizing:border-box}.post-container{background:#fff;padding:30rpx;margin:20rpx 32rpx;border-radius:20rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.03);box-sizing:border-box}.post-header{border-bottom:1rpx solid #f0f0f0;padding-bottom:20rpx;margin-bottom:20rpx}.post-title{font-size:36rpx;font-weight:700;color:#1f1f1f;margin-bottom:20rpx;display:block}.author-info{display:flex;align-items:center}.avatar{width:60rpx;height:60rpx;border-radius:50%;margin-right:16rpx}.author-name{font-size:26rpx;color:#666}.post-content{display:flex;flex-direction:column;gap:20rpx}.content-img{width:100%;border-radius:8rpx}.content-text{font-size:28rpx;color:#444;line-height:1.6}.action-area{display:flex;flex-direction:row;justify-content:flex-start;gap:30rpx;margin-top:20rpx}.action-section{display:flex;align-items:center;background:#f5f7fa;padding:16rpx 32rpx;border-radius:40rpx;transition:transform .1s}.action-section:active{transform:scale(.95)}.action-icon{font-size:32rpx;margin-right:10rpx}.action-text{font-size:28rpx;color:#333}