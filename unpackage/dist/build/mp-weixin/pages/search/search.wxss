.page{display:flex;flex-direction:column;min-height:100vh;background-color:#f5f7fa;padding-bottom:env(safe-area-inset-bottom);width:100%;box-sizing:border-box}.search-header{display:flex;align-items:center;padding:20rpx 30rpx;background-color:#fff;border-bottom:1rpx solid #eeeeee;box-sizing:border-box}.search-bar{flex:1;display:flex;align-items:center;background:#f2f2f2;border-radius:40rpx;padding:12rpx 24rpx;box-sizing:border-box}.search-icon{font-size:36rpx;color:#999;margin-right:12rpx}.search-input{flex:1;font-size:28rpx;color:#333;background:transparent;border:none;outline:none}.clear-icon{font-size:32rpx;color:#ccc;margin-left:10rpx;padding:4rpx}.cancel-btn{margin-left:20rpx;font-size:30rpx;color:#333}.search-panel{padding:30rpx 32rpx;box-sizing:border-box}.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx;margin-top:20rpx}.section-title{font-size:32rpx;font-weight:700;color:#333}.clear-history{font-size:26rpx;color:#999}.flex-wrap{display:flex;flex-wrap:wrap;gap:20rpx}.tag{background:#f0f0f0;padding:10rpx 28rpx;border-radius:30rpx;font-size:26rpx;color:#333}.hot-tags-wrapper{background:#f0f0f0;border-radius:30rpx;padding:20rpx 24rpx;display:flex;flex-wrap:wrap;gap:20rpx}.hot-tag{background:#e5e5e5;padding:10rpx 28rpx;border-radius:30rpx;font-size:26rpx;color:#333}.category-section{margin-top:20rpx}.category-grid{display:flex;justify-content:space-around;padding:10rpx 0}.category-item{display:flex;flex-direction:column;align-items:center}.circle-icon{width:100rpx;height:100rpx;background:#f0f0f0;border-radius:50%;display:flex;justify-content:center;align-items:center;margin-bottom:12rpx}.category-icon-text{font-size:48rpx}.category-name{font-size:28rpx;color:#333}.more-btn-wrapper{display:flex;justify-content:center;margin-top:40rpx;margin-bottom:60rpx}.more-btn{background:#e5e5e5;padding:12rpx 60rpx;border-radius:40rpx;font-size:28rpx;color:#444}.result-list{flex:1;padding:0 30rpx;background-color:#fff;box-sizing:border-box}.result-item{padding:24rpx 0;border-bottom:1rpx solid #f0f0f0}.item-title{font-size:30rpx;color:#333;display:block;margin-bottom:8rpx}.item-desc{font-size:24rpx;color:#999;display:block}.empty-tip{text-align:center;color:#999;margin-top:100rpx;font-size:28rpx}