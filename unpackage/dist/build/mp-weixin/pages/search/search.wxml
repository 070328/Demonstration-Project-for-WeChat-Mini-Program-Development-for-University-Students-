<view class="page"><view class="search-header"><view class="search-bar"><text class="iconfont icon-sousuokuang search-icon"></text><input class="search-input" focus="{{true}}" placeholder="搜索Boss/武器/攻略" confirm-type="search" bindconfirm="{{a}}" value="{{b}}" bindinput="{{c}}"/><text wx:if="{{d}}" class="iconfont icon-clear clear-icon" bindtap="{{e}}"></text></view><text class="cancel-btn" bindtap="{{f}}">取消</text></view><view wx:if="{{g}}" class="search-panel"><view wx:if="{{h}}" class="history-section"><view class="section-header"><text class="section-title">搜索历史</text><text class="clear-history" bindtap="{{i}}">清除</text></view><view class="tag-list flex-wrap"><text wx:for="{{j}}" wx:for-item="item" wx:key="b" class="tag" bindtap="{{item.c}}">{{item.a}}</text></view></view><view class="hot-section"><view class="section-header"><text class="section-title">热门搜索</text></view><view class="hot-tags-wrapper"><text wx:for="{{k}}" wx:for-item="item" wx:key="b" class="hot-tag" bindtap="{{item.c}}">{{item.a}}</text></view></view><view class="category-section"><view class="section-header"><text class="section-title">搜索分类</text></view><view class="category-grid"><view wx:for="{{l}}" wx:for-item="item" wx:key="c" class="category-item" bindtap="{{item.d}}"><view class="circle-icon"><text class="category-icon-text">{{item.a}}</text></view><text class="category-name">{{item.b}}</text></view></view></view><view class="more-btn-wrapper"><view class="more-btn" bindtap="{{m}}">更多</view></view></view><view wx:else class="result-list"><view wx:if="{{n}}" class="empty-tip">暂无相关结果</view><view wx:for="{{o}}" wx:for-item="item" wx:key="c" class="result-item" bindtap="{{item.d}}"><text class="item-title">{{item.a}}</text><text class="item-desc">{{item.b}}</text></view></view></view>