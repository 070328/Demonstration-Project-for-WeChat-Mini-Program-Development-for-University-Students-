<view class="page"><view wx:if="{{a}}" class="notice-container"><view class="date-group"><text class="date-title">刚刚</text></view><view wx:for="{{b}}" wx:for-item="item" wx:key="f" class="notice-item" bindtap="{{item.g}}"><image class="avatar" src="{{item.a}}" mode="aspectFill"></image><view class="content"><view class="content-top"><text class="title">{{item.b}}</text><text class="time">{{item.c}}</text></view><text class="desc">{{item.d}}</text></view><view wx:if="{{item.e}}" class="status-badge"><text class="badge-text">新</text></view></view><view class="date-group"><text class="date-title">今天</text></view><view wx:for="{{c}}" wx:for-item="item" wx:key="f" class="notice-item" bindtap="{{item.g}}"><image class="avatar" src="{{item.a}}" mode="aspectFill"></image><view class="content"><view class="content-top"><text class="title">{{item.b}}</text><text class="time">{{item.c}}</text></view><text class="desc">{{item.d}}</text></view><view wx:if="{{item.e}}" class="status-badge"><text class="badge-text">新</text></view></view></view><view wx:else class="login-prompt"><text class="prompt-icon">🔒</text><text class="prompt-text">您还未登录，请先登录以查看最新通知</text><button class="prompt-btn" bindtap="{{d}}">去登录</button></view></view>